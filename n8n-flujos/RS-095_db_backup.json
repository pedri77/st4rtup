{
  "name": "RS-095 — Database Backup Weekly",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 3 * * 0" }] }
      },
      "name": "Cron Domingo 3:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "notes": "Backup semanal de la base de datos"
    },
    {
      "parameters": {
        "command": "pg_dump -h $FLY_PG_HOST -U $FLY_PG_USER -d riskitera_sales_backend --format=custom -f /tmp/backup_$(date +%Y%m%d).dump"
      },
      "name": "pg_dump",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [470, 300],
      "notes": "Requiere acceso SSH a Fly.io Postgres. Alternativa: usar fly proxy + pg_dump local"
    },
    {
      "parameters": {
        "url": "https://api.telegram.org/bot{{$env.TELEGRAM_BOT_TOKEN}}/sendMessage",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": \"{{$env.TELEGRAM_CHAT_ID}}\",\n  \"text\": \"💾 Backup DB completado: riskitera_sales_backend ({{$now.format('yyyy-MM-dd')}})\",\n  \"parse_mode\": \"HTML\"\n}"
      },
      "name": "Telegram Confirmación",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [690, 300]
    }
  ],
  "connections": {
    "Cron Domingo 3:00": { "main": [[{ "node": "pg_dump", "type": "main", "index": 0 }]] },
    "pg_dump": { "main": [[{ "node": "Telegram Confirmación", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "timezone": "Europe/Madrid" },
  "tags": [{ "name": "backup" }, { "name": "database" }],
  "meta": { "code": "RS-095", "category": "sistema", "priority": "alta" }
}
