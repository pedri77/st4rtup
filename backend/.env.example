# St4rtup CRM - Backend Environment Variables

# App Configuration
APP_NAME=st4rtup
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://user:password@host:5432/st4rtup_crm

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Auth
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Email (Resend API)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=hello@st4rtup.app

# Webhook Secrets (HMAC-SHA256 signature verification)
TYPEFORM_WEBHOOK_SECRET=
TALLY_WEBHOOK_SECRET=
SURVEY_WEBHOOK_SECRET=

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin
ADMIN_EMAILS=admin@st4rtup.app

# Server
PORT=8001
