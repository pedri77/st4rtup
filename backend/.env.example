# St4rtup CRM - Backend Environment Variables

# App Configuration
APP_NAME=st4rtup
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# Database (PostgreSQL via Supabase)
DATABASE_URL=<CHANGE_ME:postgresql://user:password@host:5432/db>

# Supabase
SUPABASE_URL=<CHANGE_ME:https://yourproject.supabase.co>
SUPABASE_ANON_KEY=<CHANGE_ME:supabase_anon_jwt>
SUPABASE_SERVICE_ROLE_KEY=<CHANGE_ME:supabase_service_role_jwt>

# JWT Auth — SECRET_KEY must be >=32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<CHANGE_ME:generate_64_char_random_string>
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Credential encryption at-rest (Fernet key). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this, OAuth tokens in DB stay plaintext (dev mode).
CREDENTIAL_ENCRYPTION_KEY=<CHANGE_ME:fernet_key>

# Email (Resend API)
RESEND_API_KEY=<CHANGE_ME:re_xxx>
EMAIL_FROM=hello@st4rtup.app

# Webhook Secrets (HMAC-SHA256 signature verification)
TYPEFORM_WEBHOOK_SECRET=
TALLY_WEBHOOK_SECRET=
SURVEY_WEBHOOK_SECRET=

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin
ADMIN_EMAILS=admin@st4rtup.app

# Server
PORT=8001
